{
  "openapi": "3.0.0",
  "info": {
    "title": "API WSP Finance",
    "version": "1.0.0",
    "description": "API para gestão financeira híbrida (Pessoal e Empresarial). Documentação gerada automaticamente via swagger-autogen."
  },
  "servers": [
    {
      "url": "http://localhost:3333",
      "description": "Servidor de Desenvolvimento"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Registrar Novo Usuário",
        "description": "Cria uma conta no sistema e dispara o e-mail transacional com código PIN de validação.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/session": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Iniciar Sessão (Login)",
        "description": "Autentica um usuário via e-mail e senha, retornando o Access Token (JWT curto) e o Refresh Token.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/refresh": {
      "patch": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Renovar Token de Acesso",
        "description": "Utiliza um Refresh Token válido para expedir uma nova sessão limpa sem solicitar login novamente.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Verificar E-mail (Código Opt-in)",
        "description": "Confirmar o código PIN recebido no e-mail para ativar a conta Pessoal no sistema.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/resend-verification": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Reenviar PIN de Ativação",
        "description": "Gera e envia um novo código numérico de validação para o usuário logar.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Obter Perfil do Usuário Autenticado",
        "description": "Retorna o perfil completo do utilizador com as memberships (workspaces) atualizadas. Resolve o problema de sincronização após aceitar convites ou refresh da página (F5).",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "Perfil retornado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "CLIENT",
                        "ACCOUNTANT"
                      ]
                    },
                    "memberships": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer"
                          },
                          "name": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string",
                            "enum": [
                              "PERSONAL",
                              "BUSINESS"
                            ]
                          },
                          "role": {
                            "type": "string",
                            "enum": [
                              "OWNER",
                              "EDITOR",
                              "VIEWER",
                              "ACCOUNTANT"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado"
          },
          "404": {
            "description": "Usuário não encontrado"
          }
        }
      }
    },
    "/password/forgot": {
      "post": {
        "tags": [
          "Recuperação"
        ],
        "summary": "Esqueci a Senha",
        "description": "Dispara um e-mail transacional contendo o token de seis dígitos (OTP) para alterar credenciais.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/password/reset": {
      "post": {
        "tags": [
          "Recuperação"
        ],
        "summary": "Aplicar Nova Senha",
        "description": "Recebe o token enviado via e-mail e a nova senha para registrar a alteração e desbloquear o perfil.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/external/document/{cnpj}": {
      "get": {
        "tags": [
          "Integrações"
        ],
        "summary": "Consultar CNPJ (Receita Federal)",
        "description": "Limpa, formata e consulta automaticamente um CNPJ retornando Razão Social, Nome Fantasia e CNAE Ativo.",
        "parameters": [
          {
            "name": "cnpj",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/external/location/{cep}": {
      "get": {
        "tags": [
          "Integrações"
        ],
        "summary": "Consultar CEP (ViaCEP)",
        "description": "Busca endereço completo (Rua, Bairro, Cidade e UF) a partir de um código postal brasileiro.",
        "parameters": [
          {
            "name": "cep",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/users/profile": {
      "put": {
        "tags": [
          "Perfil do Usuário"
        ],
        "summary": "Editar Dados do Perfil",
        "description": "Atualiza o nome global do usuário vinculado ao seu token logado.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/workspaces": {
      "get": {
        "tags": [
          "Workspaces"
        ],
        "summary": "Listar os Meus Espaços",
        "description": "Lista as instâncias de atuação a que este usuário tem acesso (Ex: Seu Pessoal e Sua Empresa CNPJ).",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Workspaces"
        ],
        "summary": "Gerar Novo Workspace",
        "description": "Insere um novo Workspace (Empresarial ou Pessoal Extra) na grade organizacional da conta.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/workspaces/{id}": {
      "put": {
        "tags": [
          "Workspaces"
        ],
        "summary": "Modificar Workspace",
        "description": "Edita metadados da instância fiscal.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/workspaces/{id}/invites": {
      "post": {
        "tags": [
          "Workspaces"
        ],
        "summary": "Gerar Convite (Smart Link)",
        "description": "Cria um convite com Token Criptografado para que um contador ou editor acesse esta empresa. Apenas o OWNER pode executar.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-workspace-id",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "get": {
        "tags": [
          "Convites"
        ],
        "summary": "Listar Convites Enviados por Workspace",
        "description": "Retorna o histórico de convites emitidos por este workspace. Requer membership no workspace.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID do workspace"
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-workspace-id",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "Lista de convites enviados",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "role": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string"
                      },
                      "expiresAt": {
                        "type": "string"
                      },
                      "inviter": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/workspaces/{id}/invites/{inviteId}/revoke": {
      "post": {
        "tags": [
          "Workspaces"
        ],
        "summary": "Revogar Convite",
        "description": "Invalida um link de convite previamente gerado, bloqueando o engajamento caso o link tenha vazado.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inviteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-workspace-id",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/invites/accept": {
      "post": {
        "tags": [
          "Convites"
        ],
        "summary": "Aceitar Convite (Double Handshake)",
        "description": "Consome o token do convite. Valida se o email do destinatário bate fisicamente com o email da sessão logada antes de injetar a Role na tabela.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "Convite aceito. WorkspaceMember criado."
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Email mismatch, convite revogado ou expirado"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Token criptográfico do convite"
                  }
                },
                "required": [
                  "token"
                ]
              }
            }
          }
        }
      }
    },
    "/invites/received": {
      "get": {
        "tags": [
          "Convites"
        ],
        "summary": "Listar Convites Recebidos",
        "description": "Retorna todos os convites (qualquer status) onde o email do utilizador logado é o destinatário. Usado na Central de Convites do Contador.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "Lista de convites recebidos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "email": {
                        "type": "string"
                      },
                      "role": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string",
                        "enum": [
                          "PENDING",
                          "ACCEPTED",
                          "EXPIRED",
                          "REVOKED",
                          "REJECTED"
                        ]
                      },
                      "expiresAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "workspace": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer"
                          },
                          "name": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          }
                        }
                      },
                      "inviter": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/invites/{id}/reject": {
      "post": {
        "tags": [
          "Convites"
        ],
        "summary": "Rejeitar Convite",
        "description": "O destinatário recusa o convite. Altera status para REJECTED. Requer que o email do utilizador logado corresponda ao email do convite (Double Handshake).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "UUID do convite"
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "0": {
            "description": ""
          },
          "1": {
            "description": ""
          },
          "4": {
            "description": ""
          },
          "200": {
            "description": "Convite rejeitado com sucesso"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Email mismatch ou convite não está PENDING"
          },
          "404": {
            "description": "Convite não encontrado"
          }
        }
      }
    },
