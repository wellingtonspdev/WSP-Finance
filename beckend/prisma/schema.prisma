// Configuração do Cliente Prisma para gerar tipos TypeScript automaticamente
generator client {
  provider = "prisma-client-js"
}

// O provedor permanece PostgreSQL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum WorkspaceType {
  PERSONAL
  BUSINESS
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountType {
  CHECKING
  CASH
  SAVINGS
  INVESTMENT
}

// --- MODELOS ---

// Usuário
model User {
  id              Int                       @id @default(autoincrement())
  email           String                    @unique
  name            String
  passwordHash    String
  emailVerifiedAt DateTime?
  workspaces      Workspace[]
  refreshTokens   RefreshToken[]
  resetTokens     PasswordResetToken[]
  verifyTokens    AccountVerificationToken[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
}

// RefreshToken
model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresIn Int
  createdAt DateTime @default(now())

  @@index([userId])
}

// PasswordResetToken
model PasswordResetToken {
  id        String   @id @default(uuid())
  code      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// AccountVerificationToken
model AccountVerificationToken {
  id        String   @id @default(uuid())
  code      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Workspace
model Workspace {
  id           Int           @id @default(autoincrement())
  name         String
  type         WorkspaceType @default(PERSONAL)
  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

// Categorias
model Category {
  id          Int           @id @default(autoincrement())
  name        String
  icon        String?
  color       String?
  workspaceId Int?
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id])
  transactions Transaction[]
}

// Contas: Agora com ID Inteiro Sequencial
model Account {
  id                Int           @id @default(autoincrement()) // MUDANÇA: Int
  name              String
  type              AccountType   @default(CHECKING)
  balance           Decimal       @db.Decimal(19, 4) @default(0)
  isIncludedInTotal Boolean       @default(true)
  workspaceId       Int
  workspace         Workspace     @relation(fields: [workspaceId], references: [id])
  transactions      Transaction[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([workspaceId])
}

// Transações
model Transaction {
  id                String          @id @default(uuid())
  description       String
  amount            Decimal         @db.Decimal(19, 4)
  date              DateTime
  type              TransactionType
  
  grossAmount       Decimal?        @db.Decimal(19, 4)
  marketplaceFee    Decimal?        @db.Decimal(19, 4)
  shippingCost      Decimal?        @db.Decimal(19, 4)
  productCost       Decimal?        @db.Decimal(19, 4)

  isPaid            Boolean         @default(true)
  isFixed           Boolean         @default(false)
  isTaxDeductible   Boolean         @default(false)

  attachmentUrl     String?
  hashDeduplication String?         @unique

  // Relacionamentos
  accountId         Int             // MUDANÇA: Int
  account           Account         @relation(fields: [accountId], references: [id])
  categoryId        Int
  category          Category        @relation(fields: [categoryId], references: [id])
  workspaceId       Int
  workspace         Workspace       @relation(fields: [workspaceId], references: [id])

  createdAt         DateTime        @default(now())
  deleted_at        DateTime?

  @@index([workspaceId, date])
  @@index([accountId])
}