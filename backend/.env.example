# Ambiente
NODE_ENV=development
PORT=3333

# Database
DATABASE_URL="postgresql://postgres:suasenha@localhost:6543/nomedobanco?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://postgres:suasenha@localhost:5432/nomedobanco?schema=public"
PRISMA_CONNECTION_LIMIT=1
FUZZY_DEDUP_MODE="auto"

# Auth
JWT_SECRET="super_secret_jwt"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="super_secret_refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# App URL (Usado pelo CORS e Rota de Upload Local Legada)
APP_URL="http://localhost:3333"
OPEN_FINANCE_WEBHOOK_KEY="webhook-auth-key-mock"
OPEN_FINANCE_BENCHMARK_PORT=3334

# APIs Externas (Circuit Breaker Integrations)
RECEITA_WS_TOKEN="opcional_se_comprado"

# AI Insights (safe defaults; worker is not auto-started)
AI_PROVIDER="fake"
AI_INSIGHTS_WORKER_ENABLED="false"

# ----------------------------------------------------
# ☁️ CLOUDFLARE R2 SECRETS (S3-Compatible Storage)
# ----------------------------------------------------
# O Account ID pode ser extraído da Dashboard R2 à direita
R2_ACCOUNT_ID="seu-account-id-cloudflare-aqui"

# Chaves geradas na aba "R2 API Tokens"
R2_ACCESS_KEY_ID="sua-access-key-id-aqui"
R2_SECRET_ACCESS_KEY="sua-secret-access-key-aqui"

# O nome exato que você escolheu no ato da criação do bucket
R2_BUCKET_NAME="wsp-finance-vault"

# (Opcional) URL de domínio customizado atribuída ao Bucket nas configurações do R2 para leitura
R2_PUBLIC_DEV_URL="https://sub.seudominio.com"

# ----------------------------------------------------
# 🔒 COFRE: Criptografia de Envelope (SSE-C Mestra)
# ----------------------------------------------------
# Utilizado restritivamente para subir arquivos de Certificado A1 (.pfx / .p12). 
# Deve conter no mínimo 32 caracteres (256-bits) gerados de forma forte.
VAULT_MASTER_KEY="coloque_uma_rash_forte_de_mais_de_32_bytes_aqui!!"
