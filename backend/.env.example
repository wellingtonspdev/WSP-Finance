# Environment
NODE_ENV=development
PORT=3333

# Database
# Application runtime. For local PostgreSQL without pooler, use port 5432.
DATABASE_URL="postgresql://postgres:LOCAL_PASSWORD@localhost:5432/wsp_finance?schema=public"
# Direct connection for migrations, seed and tests.
DIRECT_URL="postgresql://postgres:LOCAL_PASSWORD@localhost:5432/wsp_finance?schema=public"
PRISMA_CONNECTION_LIMIT=1
FUZZY_DEDUP_MODE="auto"

# Auth
# Generate strong values locally. Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_ME_GENERATE_32_BYTES_MINIMUM"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="CHANGE_ME_GENERATE_ANOTHER_32_BYTES_MINIMUM"
JWT_REFRESH_EXPIRES_IN="7d"

# App URL (Used by CORS and Legacy Local Upload Route)
APP_URL="http://localhost:3333"
OPEN_FINANCE_WEBHOOK_KEY="webhook-auth-key-mock"
OPEN_FINANCE_BENCHMARK_PORT=3334

# External APIs (Circuit Breaker Integrations)
RECEITA_WS_TOKEN="optional_if_purchased"

# AI Insights (safe defaults; worker is not auto-started)
AI_PROVIDER="fake"
AI_INSIGHTS_WORKER_ENABLED="false"

# ----------------------------------------------------
# CLOUDFLARE R2 SECRETS (S3-Compatible Storage)
# ----------------------------------------------------
# Account ID can be extracted from R2 Dashboard
R2_ACCOUNT_ID="your-cloudflare-account-id-here"

# Keys generated in "R2 API Tokens" tab
R2_ACCESS_KEY_ID="your-access-key-id-here"
R2_SECRET_ACCESS_KEY="your-secret-access-key-here"

# The exact name chosen during bucket creation
R2_BUCKET_NAME="wsp-finance-vault"

# (Optional) Custom domain URL assigned to the Bucket
R2_PUBLIC_DEV_URL="https://sub.yourdomain.com"

# ----------------------------------------------------
# VAULT: Envelope Encryption (SSE-C Master Key)
# ----------------------------------------------------
# Used exclusively for uploading A1 Certificate files (.pfx / .p12).
# Must contain at least 32 characters (256-bits) generated securely.
VAULT_MASTER_KEY="put_a_strong_hash_with_more_than_32_bytes_here!!"

# ----------------------------------------------------
# TELEGRAM INTEGRATION (POC S5-012)
# ----------------------------------------------------
# BotFather token for Telegram API
TELEGRAM_BOT_TOKEN=""
# Enable bot polling (false in production, use webhook)
TELEGRAM_BOT_ENABLED="false"
# Bot username without @ (e.g. WSPFinanceBot)
TELEGRAM_BOT_USERNAME=""
# Secret to sign confirmation/cancellation callbacks
TELEGRAM_CALLBACK_SECRET=""
# Secret to sign pairing JWT tokens
TELEGRAM_LINK_TOKEN_SECRET="CHANGE_ME_FOR_TELEGRAM_LOCAL_OR_KEEP_DISABLED"
# Pairing token TTL in seconds (default: 600 = 10min)
TELEGRAM_LINK_TOKEN_TTL_SECONDS="600"
# Secret for HMAC-SHA256 of Telegram identifiers (chatId, userId)
TELEGRAM_IDENTIFIER_HASH_SECRET="CHANGE_ME_FOR_TELEGRAM_LOCAL_OR_KEEP_DISABLED"
# Maximum file size accepted by OCR in bytes (default: 5MB)
TELEGRAM_MAX_FILE_SIZE_BYTES="5242880"
# OCR Provider: "fake" for tests, "tesseract" for real OCR
OCR_PROVIDER="fake"
