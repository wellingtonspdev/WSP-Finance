# Test environment for backend Vitest.
# Copy to backend/.env.test or merge these values into backend/.env before running pnpm test.

NODE_ENV=test
PORT=3333

# Tests need a real local PostgreSQL database because they validate RLS behavior.
DATABASE_URL="postgresql://postgres:LOCAL_PASSWORD@localhost:5432/wsp_finance_test?schema=public"
DIRECT_URL="postgresql://postgres:LOCAL_PASSWORD@localhost:5432/wsp_finance_test?schema=public"

PRISMA_CONNECTION_LIMIT=1
FUZZY_DEDUP_MODE="auto"

JWT_SECRET="test-jwt-secret-with-at-least-32-characters"
JWT_REFRESH_SECRET="test-refresh-secret-with-at-least-32-characters"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

APP_URL="http://localhost:3333"
OPEN_FINANCE_WEBHOOK_KEY="webhook-auth-key-test"
OPEN_FINANCE_BENCHMARK_PORT=3334

AI_PROVIDER="fake"
AI_INSIGHTS_WORKER_ENABLED="false"
OCR_PROVIDER="fake"
TELEGRAM_BOT_ENABLED="false"
