// Configuração do Cliente Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---
enum UserType {
  CLIENT
  ACCOUNTANT
}

enum SystemRole {
  USER
  ADMIN
}

enum WorkspaceType {
  PERSONAL
  BUSINESS
}

enum DocumentType {
  CPF
  CNPJ
  PASSPORT
}

// Fechamento e Importações
enum MovementSource {
  OFX
  OPEN_FINANCE
  OCR
  MANUAL
  TELEGRAM_OCR
}

enum MovementStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

// Master / App Core
enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountType {
  CHECKING
  CASH
  SAVINGS
  INVESTMENT
  CREDIT_CARD
}

enum TransactionStatus {
  PENDING // Pendente de conciliação/pagamento
  COMPLETED // Efetivado
  RECONCILED // Conciliado com extrato bancário
}

enum WorkspaceRole {
  OWNER // Acesso total (pode deletar workspace)
  EDITOR // Pode criar/editar transações
  VIEWER // Somente leitura (Contador)
  ACCOUNTANT // Conta de Contador B2B2C
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  BRIDGE_TRANSFER // Nova ação para auditoria de ponte
  ATTACHMENT_VIEW // Fase C: Auditoria de visualização de anexo
  CATEGORY_UPDATE // Fase C: Auditoria de alteração de categoria
  EXPORT
  OCR_INGESTION
  OCR_CONFIRMATION
  OCR_CANCELLATION
  TELEGRAM_LINK_CREATED
  TELEGRAM_LINK_REVOKED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum AiInsightSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AiInsightCode {
  MISTURA_PATRIMONIAL
  RISCO_MALHA_FINA
  DESPESA_PESSOAL_POTENCIAL
}

enum RecurringProLaborePendingStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// --- MODELOS ---

// Usuário
model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  name            String
  passwordHash    String
  emailVerifiedAt DateTime?
  type            UserType  @default(CLIENT)
  systemRole      SystemRole @default(USER)

  // Informações Pessoais & Endereço
  cpf          String? @unique
  phone        String?
  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  // Relacionamentos
  memberships   WorkspaceMember[] // RBAC: Um usuário pode ser membro de vários workspaces
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  verifyTokens  AccountVerificationToken[]
  auditLogs     AuditLog[]
  notifications Notification[]
  invitesSent   WorkspaceInvite[]          @relation("InvitesSent")
  dashboardCaches AccountantDashboardCache[]
  exportArchivesCreated ExportArchive[] @relation("ExportArchiveCreatedBy")
  recurringProLaboreSchedulesCreated RecurringProLaboreSchedule[] @relation("RecurringProLaboreScheduleCreatedBy")
  recurringProLaborePendingsProcessing RecurringProLaborePending[] @relation("RecurringProLaborePendingProcessingBy")
  recurringProLaborePendingsConfirmed RecurringProLaborePending[] @relation("RecurringProLaborePendingConfirmedBy")
  recurringProLaborePendingsCancelled RecurringProLaborePending[] @relation("RecurringProLaborePendingCancelledBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// RBAC: Tabela de Associação Usuário <-> Workspace
model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  userId      Int
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId Int
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now())

  @@unique([userId, workspaceId]) // Um usuário só pode ter um cargo por workspace
  @@index([userId])
  @@index([workspaceId])
}

// Workspace
model Workspace {
  id      Int           @id @default(autoincrement())
  name    String
  type    WorkspaceType @default(PERSONAL)
  taxRate Decimal       @default(0) @db.Decimal(5, 2) // Taxa de imposto padrão (%)

  // Identidade Fiscal
  document     String?
  documentType DocumentType?
  cnae         String?

  // Endereço Comercial
  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  // Governança e Fecho Fiscal
  closedUntil DateTime?
  certificateObjectKey   String?
  certificateExpiresAt   DateTime?

  // Relacionamentos
  members       WorkspaceMember[] // Membros do workspace
  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  invites       WorkspaceInvite[]
  bankMovements BankMovement[]
  dashboardCaches AccountantDashboardCache[]

  // Exportação Contábil
  accountingExportConfigs AccountingExportConfig[]
  accountingExportMappings AccountingExportMapping[]
  exportArchives ExportArchive[]
  outboxEvents OutboxEvent[]
  aiInsights   AiInsight[]
  proLaboreSchedulesFrom RecurringProLaboreSchedule[] @relation("RecurringProLaboreScheduleSourceWorkspace")
  proLaboreSchedulesTo   RecurringProLaboreSchedule[] @relation("RecurringProLaboreScheduleDestinationWorkspace")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecurringProLaboreSchedule {
  id                     String    @id @default(uuid())
  sourceWorkspaceId      Int
  sourceWorkspace        Workspace @relation("RecurringProLaboreScheduleSourceWorkspace", fields: [sourceWorkspaceId], references: [id], onDelete: Restrict)
  destinationWorkspaceId Int
  destinationWorkspace   Workspace @relation("RecurringProLaboreScheduleDestinationWorkspace", fields: [destinationWorkspaceId], references: [id], onDelete: Restrict)
  amount                 Decimal   @db.Decimal(19, 4)
  dayOfMonth             Int
  description            String
  isActive               Boolean   @default(true)
  createdByUserId        Int
  createdByUser          User      @relation("RecurringProLaboreScheduleCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  deactivatedAt          DateTime?
  deactivatedByUserId    Int?
  pendings               RecurringProLaborePending[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([sourceWorkspaceId])
  @@index([destinationWorkspaceId])
  @@index([isActive, dayOfMonth])
  @@index([createdByUserId])
}

model RecurringProLaborePending {
  id                 String                          @id @default(uuid())
  scheduleId         String
  schedule           RecurringProLaboreSchedule      @relation(fields: [scheduleId], references: [id], onDelete: Restrict)
  competence         DateTime
  status             RecurringProLaborePendingStatus @default(PENDING)
  bridgeId           String?                         @unique
  processingStartedAt DateTime?
  processingByUserId Int?
  processingByUser   User?                           @relation("RecurringProLaborePendingProcessingBy", fields: [processingByUserId], references: [id], onDelete: SetNull)
  confirmedByUserId  Int?
  confirmedByUser    User?                           @relation("RecurringProLaborePendingConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  confirmedAt        DateTime?
  cancelledByUserId  Int?
  cancelledByUser    User?                           @relation("RecurringProLaborePendingCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  cancelledAt        DateTime?
  lastAttemptAt      DateTime?
  lastError          String?                         @db.VarChar(1000)
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  @@unique([scheduleId, competence])
  @@index([status, competence])
  @@index([processingByUserId])
  @@index([confirmedByUserId])
  @@index([cancelledByUserId])
}

// Macro Categoria (Catálogo WSP)
model MacroCategory {
  id        Int             @id @default(autoincrement())
  code      String          @unique
  name      String
  type      TransactionType
  group     String?
  isActive  Boolean         @default(true)
  categories Category[]
  accountingExportMappings AccountingExportMapping[]

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// Categorias
model Category {
  id           Int           @id @default(autoincrement())
  name         String
  icon         String?
  color        String?
  workspaceId  Int? // Null = Global
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])
  macroCategoryId Int?
  macroCategory MacroCategory? @relation(fields: [macroCategoryId], references: [id])
  transactions Transaction[]

  @@index([workspaceId])
  @@index([macroCategoryId])
}

// Contas
model Account {
  id                Int            @id @default(autoincrement())
  name              String
  type              AccountType    @default(CHECKING)
  balance           Decimal        @default(0) @db.Decimal(19, 4)
  isIncludedInTotal Boolean        @default(true)
  workspaceId       Int
  workspace         Workspace      @relation(fields: [workspaceId], references: [id])
  transactions      Transaction[]
  bankMovements     BankMovement[]
  auditLogsAsFrom   AuditLog[]     @relation("AuditLogFromAccount")
  auditLogsAsTo     AuditLog[]     @relation("AuditLogToAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

// Transações
model Transaction {
  id          String            @id @default(uuid()) // UUID para segurança externa
  description String
  amount      Decimal           @db.Decimal(19, 4)
  date        DateTime
  dueDate     DateTime? // Data de vencimento (Contas a Pagar/Receber)
  type        TransactionType
  status      TransactionStatus @default(COMPLETED)

  // Campos Analíticos de Marketplace
  grossAmount     Decimal? @db.Decimal(19, 4)
  marketplaceFee  Decimal? @db.Decimal(19, 4)
  shippingCost    Decimal? @db.Decimal(19, 4)
  productCost     Decimal? @db.Decimal(19, 4)
  taxAmount       Decimal? @db.Decimal(19, 4) // Valor reservado para impostos
  netValue        Decimal? @db.Decimal(19, 4) // Valor líquido real recebido
  feeAmount       Decimal? @db.Decimal(19, 4) // Taxa de gateway / intermediador
  platformFeeRate Decimal? @db.Decimal(5, 2) // % Taxa da plataforma (Shopee, etc)

  isPaid          Boolean @default(true)
  isFixed         Boolean @default(false)
  isTaxDeductible Boolean @default(false)

  attachmentUrl  String?
  attachmentSize Int?    @default(0) // Tamanho empírico do arquivo em bytes (V3.8 Governança)

  // Deduplicação OFX
  fitid             String? // ID único do banco (Financial Institution Transaction ID)
  hashDeduplication String? // Fallback MD5

  // Relacionamentos
  accountId   Int
  account     Account   @relation(fields: [accountId], references: [id])
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  createdAt DateTime  @default(now())
  deletedAt DateTime? // Soft Delete (Auditoria)

  aiInsights  AiInsight[]

  @@unique([workspaceId, fitid]) // Garante unicidade do FITID dentro do workspace
  @@unique([workspaceId, hashDeduplication])
  @@unique([workspaceId, id]) // FK composta tenant-safe para AiInsight
  @@index([workspaceId, date])
  @@index([accountId])
  @@index([workspaceId, attachmentSize]) // V3.8 Performance Engine: Acelera SUM() de Cota
}

// Auditoria (Governança)
model AuditLog {
  id             String      @id @default(uuid())
  userId         Int
  user           User        @relation(fields: [userId], references: [id])
  workspaceId    Int?
  action         AuditAction
  entity         String // Ex: "Transaction", "Account"
  entityId       String // ID da entidade afetada (pode ser Int convertido pra String)
  oldState       Json? // Estado anterior (para rollback/histórico)
  newState       Json? // Novo estado
  balanceBefore  Decimal?    @db.Decimal(19, 4)
  balanceAfter   Decimal?    @db.Decimal(19, 4)
  delta          Decimal?    @db.Decimal(19, 4)
  fromAccount    Int?
  fromAccountRef Account?    @relation("AuditLogFromAccount", fields: [fromAccount], references: [id])
  toAccount      Int?
  toAccountRef   Account?    @relation("AuditLogToAccount", fields: [toAccount], references: [id])
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([fromAccount])
  @@index([toAccount])
}

// Notificações (Automação)
model Notification {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- TABELAS DE SUPORTE (Auth) ---

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresIn Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  code      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AccountVerificationToken {
  id        String   @id @default(uuid())
  code      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Convites Onboarding (Double Handshake)
model WorkspaceInvite {
  id     String        @id @default(uuid())
  email  String
  role   WorkspaceRole @default(ACCOUNTANT)
  token  String        @unique
  status InviteStatus  @default(PENDING)

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  inviterId Int
  inviter   User @relation("InvitesSent", fields: [inviterId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([workspaceId])
  @@index([email])
}

// Importações Bancárias (Área de Staging - Amortecedor)
model BankMovement {
  id          String    @id @default(uuid())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  accountId   Int
  account     Account   @relation(fields: [accountId], references: [id])

  amount      Decimal        @db.Decimal(19, 4)
  date        DateTime
  description String
  source      MovementSource
  status      MovementStatus @default(PENDING)

  fitid             String?
  hashDeduplication String?
  rawPayload        Json // Payload original do banco/ofx

  createdAt DateTime @default(now())

  @@unique([workspaceId, fitid])
  @@unique([workspaceId, hashDeduplication])
  @@index([workspaceId, status])
  @@index([workspaceId, status, amount, date(sort: Desc)], map: "idx_bank_movements_workspace_status_amount_date")
  @@index([description(ops: raw("gin_trgm_ops"))], map: "idx_bank_movements_description_trgm", type: Gin)
}

// Cache de Dashboard do Contador (Agregação Multi-Workspace)
model AccountantDashboardCache {
  id                 Int       @id @default(autoincrement())
  userId             Int
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId        Int
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pendingMovements   Int       @default(0)
  missingAttachments Int       @default(0)
  cashRiskAlert      Boolean   @default(false)
  totalBalance       Decimal   @default(0) @db.Decimal(19, 4)
  certificateExpiresAt DateTime?
  updatedAt          DateTime  @updatedAt

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

// Configuração de Exportação Contábil (Tenant-Scoped)
model AccountingExportConfig {
  id                  Int       @id @default(autoincrement())
  workspaceId         Int
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  targetSystem        String // Ex: "DOMINIO"
  layoutId            String // Ex: "dominio-separated-v1"
  companyCode         String // Obrigatório (não vazio)
  branchCode          String?
  sourceLabel         String    @default("WSP")
  historyCodeRequired Boolean   @default(false)
  isActive            Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, layoutId])
  @@index([workspaceId])
}

// Mapeamento de Exportação Contábil De-Para (Tenant-Scoped)
model AccountingExportMapping {
  id                Int      @id @default(autoincrement())
  workspaceId       Int
  macroCategoryId   Int
  layoutId          String
  targetSystem      String

  debitAccountCode  String
  creditAccountCode String
  historyCode       String?
  costCenterCode    String?

  isActive          Boolean  @default(true)
  createdByUserId   Int?
  updatedByUserId   Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace     @relation(fields: [workspaceId], references: [id])
  macroCategory     MacroCategory @relation(fields: [macroCategoryId], references: [id])

  @@unique([workspaceId, macroCategoryId, layoutId])
  @@index([workspaceId])
  @@index([macroCategoryId])
}

model ExportArchive {
  id              String    @id @default(uuid())
  workspaceId     Int
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId Int
  createdByUser   User      @relation("ExportArchiveCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  layoutId        String    // Ex: "dominio-separated-v1"
  targetSystem    String    // Ex: "DOMINIO"
  periodStart     DateTime
  periodEnd       DateTime

  fileName        String
  objectKey       String    // Chave opaca no R2 (ex: workspaces/{workspaceId}/exports/{uuid}.txt)
  sha256          String    // SHA-256 do arquivo gerado
  sizeBytes       Int
  recordCount     Int
  contentType     String
  encoding        String
  warningsCount   Int
  retentionUntil  DateTime
  createdAt       DateTime  @default(now())

  @@unique([workspaceId, objectKey])
  @@index([workspaceId, sha256])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, periodStart, periodEnd])
  @@index([workspaceId, targetSystem, layoutId])
  @@index([retentionUntil])
}

model OutboxEvent {
  id            String       @id @default(uuid())
  workspaceId   Int
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  nextAttemptAt DateTime     @default(now())
  lastError     String?      @db.VarChar(1000)
  createdAt     DateTime     @default(now())
  processedAt   DateTime?

  @@index([workspaceId])
  @@index([status, nextAttemptAt])
  @@index([eventType])
}

model AiInsight {
  id            String            @id @default(uuid())
  workspaceId   Int
  transactionId String

  severity      AiInsightSeverity
  code          AiInsightCode
  message       String
  reason        String
  confidence    Decimal           @db.Decimal(5, 4)
  dismissed     Boolean           @default(false)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transaction   Transaction       @relation(fields: [workspaceId, transactionId], references: [workspaceId, id], onDelete: Cascade)

  @@unique([workspaceId, transactionId, code])
  @@index([workspaceId])
  @@index([transactionId])
  @@index([workspaceId, dismissed])
  @@index([workspaceId, createdAt])
}

// Vínculo Persistente Telegram ↔ Usuário
model TelegramUserLink {
  id                 String   @id @default(uuid())
  telegramChatIdHash String
  telegramUserIdHash String?
  telegramUsername   String?
  userId             Int
  activeDestinationId String?
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  revokedAt          DateTime?

  destinations       TelegramDestination[]

  @@index([telegramChatIdHash])
  @@index([telegramUserIdHash])
  @@index([userId])
  @@index([status])
}

// Destino Configurado pelo Usuário (Empresa/Pessoal)
model TelegramDestination {
  id                       String   @id @default(uuid())
  telegramUserLinkId       String
  userId                   Int
  workspaceId              Int
  accountId                Int
  defaultExpenseCategoryId Int?
  defaultIncomeCategoryId  Int?
  label                    String?
  isDefault                Boolean  @default(false)
  status                   String   @default("ACTIVE")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  revokedAt                DateTime?

  telegramUserLink         TelegramUserLink @relation(fields: [telegramUserLinkId], references: [id], onDelete: Cascade)

  @@index([telegramUserLinkId])
  @@index([userId])
  @@index([workspaceId])
  @@index([status])
}

// Token Assinado para Conexão
model TelegramLinkToken {
  id                       String   @id @default(uuid())
  codeHash                 String   @unique
  attempts                 Int      @default(0)
  maxAttempts              Int      @default(3)
  userId                   Int

  // Opcionais se criados no momento do vínculo
  defaultWorkspaceId       Int?
  defaultAccountId         Int?
  defaultExpenseCategoryId Int?
  defaultIncomeCategoryId  Int?

  expiresAt                DateTime
  usedAt                   DateTime?
  createdAt                DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Rascunho temporário de OCR via Telegram
model TelegramOcrDraft {
  id                 String   @id @default(uuid())
  telegramChatIdHash String
  telegramUserIdHash String?
  userId             Int

  // OCR Data
  extractedData      Json
  fileId             String?

  // Dados de Destino (selecionados no fluxo)
  workspaceId        Int?
  accountId          Int?
  categoryId         Int?

  // Controle de estado
  step               String   @default("AWAITING_WORKSPACE")
  status             String   @default("PENDING")

  expiresAt          DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([telegramChatIdHash])
  @@index([userId])
  @@index([status])
}
