# WSP Finance Docker dev environment.
# Copy this file to .env.docker before running docker compose.
# Values below are local/demo placeholders. Do not use them in production.

# Database admin role used by PostgreSQL bootstrap, Prisma migrations and seed.
POSTGRES_ADMIN_USER=wsp_admin
POSTGRES_ADMIN_PASSWORD=wsp_admin_dev_password
POSTGRES_DB=wsp_finance
POSTGRES_PORT=6543

# Restricted runtime role used by the backend application.
# It is created/normalized by backend/scripts/docker-prepare-runtime-role.ts.
APP_DATABASE_USER=wsp_app
APP_DATABASE_PASSWORD=wsp_app_dev_password

# Host ports.
BACKEND_PORT=3333
FRONTEND_PORT=5173
ADMINER_PORT=8081

# Auth secrets for local/demo only. Replace if this environment is shared.
JWT_SECRET=replace_with_32_plus_chars_local_jwt_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_with_32_plus_chars_local_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Dev-safe integration defaults.
OPEN_FINANCE_WEBHOOK_KEY=webhook-auth-key-docker-dev
OPEN_FINANCE_BENCHMARK_PORT=3334
FUZZY_DEDUP_MODE=auto
AI_PROVIDER=fake
AI_INSIGHTS_WORKER_ENABLED=false
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CALLBACK_SECRET=replace_with_32_plus_chars_local_telegram_callback
TELEGRAM_LINK_TOKEN_SECRET=replace_with_32_plus_chars_local_telegram_link
TELEGRAM_LINK_TOKEN_TTL_SECONDS=600
TELEGRAM_IDENTIFIER_HASH_SECRET=replace_with_32_plus_chars_local_telegram_hash
TELEGRAM_MAX_FILE_SIZE_BYTES=5242880
OCR_PROVIDER=fake

# Optional storage placeholders. Configure real values only in a private .env.docker.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wsp-finance-vault
R2_PUBLIC_DEV_URL=http://localhost:3333/files
VAULT_MASTER_KEY=replace_with_32_plus_chars_local_vault_master_key
